# --- Telegram ---
BOT_TOKEN=123456:YOUR_BOT_TOKEN

# Public HTTPS URL where nginx terminates TLS (no trailing slash)
WEBHOOK_BASE_URL=https://bot.example.com

# Path template; must match FastAPI route + nginx location
WEBHOOK_PATH=/tg/webhook/{secret}

# Secret segment used in webhook URL (high entropy)
WEBHOOK_SECRET=change-me-long-random-string

# Optional: Telegram setWebhook secret_token header validation
# TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Set false only for local dev without a public HTTPS URL (skips setWebhook)
# WEBHOOK_REGISTER_ON_STARTUP=true

# Comma-separated Telegram user ids: each receives user forwards in private chat with the bot
ADMIN_USER_IDS=123456789,987654321

# Optional: seed first owner when admins table empty (Telegram user id)
INITIAL_OWNER_ID=123456789

# --- PostgreSQL (asyncpg DSN) ---
POSTGRES_DSN=postgresql://tg_bot:strongpassword@postgres:5432/tg_bot

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- HTTP bind (inside container usually 8000) ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Throughput tuning ---
BROADCAST_CONCURRENCY=25
BROADCAST_CHUNK_SIZE=500
USER_MESSAGE_RATE_PER_MINUTE=30
ADMIN_REPLY_RATE_PER_MINUTE=120
LIVESTREAM_COOLDOWN_SECONDS=300

# --- Pools ---
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# --- Redis keys ---
REDIS_BROADCAST_QUEUE=broadcast:jobs
REDIS_SCHEDULER_QUEUE=scheduler:jobs
REDIS_FSM_PREFIX=fsm:
REDIS_RATE_PREFIX=rate:
REDIS_LIVESTREAM_PREFIX=livestream:

STORAGE_DIR=./storage

# Post-/start onboarding drip jobs in Postgres (+1h/+1d/+3d templates); set false to disable
ONBOARDING_DRIP_ENABLED=true

# Optional path for “download full log” in admin panel (plain text file)
# LOG_FILE_PATH=/var/log/telegram-bot.log
